{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web.app .web file manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "web", "source"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Must point at this schema in the Web.app source repository at the exact build commit."
    },
    "web": {
      "const": 1
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "root"],
          "properties": {
            "kind": { "const": "local" },
            "root": {
              "type": "string",
              "pattern": "^(?:@/|\\./)"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "provider", "repo", "commit", "path"],
          "properties": {
            "kind": { "const": "git" },
            "provider": { "const": "github" },
            "repo": {
              "type": "string",
              "pattern": "^(?!\\.)(?!\\.\\.)[A-Za-z0-9_.-]+/(?!\\.)(?!\\.\\.)[A-Za-z0-9_.-]+$"
            },
            "commit": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{40}$"
            },
            "path": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
